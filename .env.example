# ============================================
# OFAC 制裁名单监控系统 - 环境变量配置
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# 飞书机器人 Webhook URL（必填）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_HERE

# 数据存储目录（可选，默认 ./data）
DATA_DIR=./data

# 日志目录（可选，默认 ./logs）
LOG_DIR=./logs
